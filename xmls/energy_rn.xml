<mxfile host="app.diagrams.net">
  <diagram name="energy_rn">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Initial -->
        <mxCell id="init" style="ellipse;shape=startState;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- States -->
        <mxCell id="Charging" value="Charging" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="180" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="Operational" value="Operational" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="180" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- Transitions -->
        <mxCell edge="1" source="init" target="Charging" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="Charging" target="Charging" value="harvest / harvestEnergy()" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="Charging" target="Operational"
          value="tick / energyResume() [self.energyLevel == self.maxEnergyLevel]" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="Charging" target="Charging"
          value="tick / updateTickCount() [self.energyLevel &lt; self.maxEnergyLevel]" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="Operational" target="Operational"
          value="consume / consumeEnergy()" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="Operational" target="Charging"
          value="tick / updateTickCount()" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="Operational" target="Operational"
          value="harvest / harvestEnergy()" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>